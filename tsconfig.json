{
  "extends": "./node_modules/@salesforce/dev-config/tsconfig-strict-esm",
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "./src",
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "strictNullChecks": false,
    "noImplicitAny": false
  },
  "include": [
    "./src/**/*"
  ]
}
